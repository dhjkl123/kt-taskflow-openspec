{
    "buildCommand": "npm install --prefix frontend 2>/dev/null || true",
    "outputDirectory": "frontend",
    "env": {
        "DATABASE_URL": "postgresql://user:password@localhost/taskflow",
        "JWT_SECRET": "production-secret-change-this-in-vercel-dashboard"
    },
    "routes": [
        {
            "src": "/(api|health|auth|teams|tasks|messages)/(.*)",
            "dest": "/api/index.py"
        },
        {
            "src": "/health",
            "dest": "/api/index.py"
        },
        {
            "src": "/(.*)",
            "dest": "/frontend/index.html"
        }
    ]
}
